# Keystatic / GitHub Storage
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# GitHub repo Keystatic writes to
NEXT_PUBLIC_GITHUB_OWNER=
NEXT_PUBLIC_GITHUB_REPO=

# Client-visible storage mode. Must match the server-side value below for Keystatic UI routing.
NEXT_PUBLIC_KEYSTATIC_STORAGE_MODE=local

# Server-side storage mode. Use 'github' on Vercel or any deployed GitHub-backed Keystatic instance.
KEYSTATIC_STORAGE_MODE=local

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Auth.js
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Comma-separated GitHub usernames permitted to access /admin
ADMIN_GITHUB_USERNAMES=
